# Copy this file to .env.local and fill in the real values.
# Do NOT commit .env.local.

# Optional: unique session-signing secret for admin cookies.
# If left empty, a built-in fallback is used (fine for internal events).
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# Baremetal face-compute service. Only this bridge talks to it.
BAREMETAL_URL=http://127.0.0.1:8000
BAREMETAL_TOKEN=

# Where registration JPEGs are stored on the bridge filesystem.
PHOTO_DIR=/var/www/project_crow/data/photos

# Avatar templates and generated posters.
AVATAR_TEMPLATE_DIR=/var/www/project_crow/data/avatar-templates
POSTERS_DIR=/var/www/project_crow/data/posters

NEXT_PUBLIC_BASE_PATH=/kelvinpahbirthday
